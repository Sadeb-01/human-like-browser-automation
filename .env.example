# Browser Configuration
BROWSER_HEADLESS=false
BROWSER_TYPE=chromium
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080
DISABLE_AUTOMATION_FEATURES=true
BROWSER_STORAGE_STATE_PATH=./browser_storage/state.json

# VLM Configuration (Phase 2+)
VLM_PROVIDER=deepseek
VLM_MODEL=deepseek-vl2
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com

# Input Configuration (Phase 3+)
USE_OS_LEVEL_INPUT=false
MOUSE_SPEED=0.5
TYPING_SPEED=0.5

# Anti-Detection Configuration (Phase 4+)
ENABLE_STEALTH_MODE=false
USE_RESIDENTIAL_PROXY=false
PROXY_URL=

# Logging
LOG_LEVEL=INFO
MEMORY_DIR=./task_memory
